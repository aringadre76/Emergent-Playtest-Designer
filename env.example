# Emergent Playtest Designer Environment Configuration

# Unity Configuration
UNITY_EXECUTABLE_PATH=/path/to/unity/executable
UNITY_PROJECT_PATH=/path/to/unity/project
HEADLESS_MODE=true
UNITY_TIMEOUT=300
UNITY_MAX_MEMORY_MB=2048

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4
OPENAI_API_KEY=your_openai_api_key_here
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# Database Configuration
DATABASE_URL=sqlite:///playtest_designer.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/playtest_designer.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT={time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}

# Testing Configuration
TEST_GAME_PATH=/path/to/test/game
MAX_TESTING_TIME=3600
MAX_EPISODES=1000
EXPLOIT_DETECTION_THRESHOLD=0.8
VIDEO_CAPTURE=true
SCREENSHOT_CAPTURE=true