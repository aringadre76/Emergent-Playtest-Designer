# ===========================================

# Configuration files with secrets
.env.local
.env.production
config.local.py
secrets.json

# Database files
*.db
*.sqlite
*.sqlite3

# Log files
*.log
logs/

# Temporary files
tmp/
temp/
.tmp/

# Docker
.dockerignore.backup

# Build artifacts
build/
dist/
*.exe
*.dmg
*.pkg

# Test results
test-results/
.nyc_output/
